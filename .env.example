# Server Configuration
PORT=3001
NODE_ENV=development
# Options: development, production, test

# CORS Configuration
# Use comma-separated origins for multiple domains
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT Authentication
# REQUIRED in production - set to a strong random value (e.g. openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 Configuration (for video storage)
# Required for cloud video storage in production
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=music-app-videos
# Optional: CloudFront URL for faster video delivery
CLOUD_FRONT_URL=

# OAuth / SSO Configuration
# Google Sign-In: obtain from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# Apple Sign-In: obtain from https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=

# Push Notifications (Web Push)
# Generate VAPID keys using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
